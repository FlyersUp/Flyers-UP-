{
  "buildCommand": "npm run build",
  "crons": [
    {
      "path": "/api/cron/expire-bookings",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/deposit-timeout",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/auto-refunds",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/bookings/payout-release",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/reminders",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/auto-confirm",
      "schedule": "0 0 * * *"
    }
  ]
}
