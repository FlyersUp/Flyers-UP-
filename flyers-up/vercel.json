    },
    {
      "path": "/api/cron/deposit-timeout",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/auto-refunds",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/release-payouts",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/reminders",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/auto-confirm",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/milestone-auto-confirm",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/recurring-generate-bookings",
