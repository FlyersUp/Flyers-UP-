# OneSignal Web Push (required for /debug/push and push notifications)
# Get your App ID from: OneSignal Dashboard → Settings → Keys & IDs
NEXT_PUBLIC_ONESIGNAL_APP_ID=your-onesignal-app-id

# Google Analytics 4 (optional). Loaded only when NODE_ENV=production.
# Admin → Data streams → Web → Measurement ID (G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=G-QDBQ2PR7FJ

# Capacitor native shell: WebView loads this URL (hosted Next.js). Omit only for placeholder www/.
# Store / production builds: MUST be your real HTTPS production domain (same host as deployed Flyers Up).
# Dev (device on LAN): http://192.168.x.x:3000
# CAPACITOR_SERVER_URL=https://your-production-host

# Official support inbox (UI mailto + ticket notification recipient unless SUPPORT_INBOX_EMAIL is set)
# NEXT_PUBLIC_OFFICIAL_SUPPORT_EMAIL=support@flyersup.app
# OFFICIAL_SUPPORT_EMAIL=support@flyersup.app
# SUPPORT_INBOX_EMAIL=support@flyersup.app
# SUPPORT_TICKET_EMAIL_NOTIFICATIONS=1
# RESEND_API_KEY= (required for ticket email notifications)
# RESEND_FROM=onboarding@resend.dev
